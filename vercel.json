{
  "buildCommand": "",
  "framework": null,
  "routes": [
    {
      "src": "^/$",
      "has": [
        {
          "type": "host",
          "value": "customize.luckycolorstone.com"
        }
      ],
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "has": [
        {
          "type": "host",
          "value": "crm.luckycolorstone.com"
        }
      ],
      "dest": "/crm.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://lucky-colorstone-designer.onrender.com/api/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
